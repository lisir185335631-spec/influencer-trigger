# ============================================================
# Influencer Trigger - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# App
APP_NAME="Influencer Trigger"
DEBUG=false

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./data/influencer.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/influencer_trigger

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption key for SMTP passwords (Fernet)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key-here

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_CLASSIFIER_MODEL=gpt-4o-mini

# Optional SOCKS5 / HTTP proxy for outbound SMTP. Leave empty for direct
# connection. Set this when the machine sits behind a proxy that intercepts
# DNS but doesn't forward SMTP (e.g. Clash/v2ray fake-ip mode).
#   SMTP_PROXY=socks5://127.0.0.1:7890   (Clash default)
#   SMTP_PROXY=http://127.0.0.1:7890     (HTTP CONNECT)
SMTP_PROXY=

# SendGrid (optional)
SENDGRID_API_KEY=SG.your-sendgrid-api-key

# Mailgun (optional)
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mg.yourdomain.com

# Redis
REDIS_URL=redis://localhost:6379

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=["http://localhost:6001","http://127.0.0.1:6001"]

# Webhook Notifications (optional)
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-token
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/slack/webhook

# Brave Search (powers Instagram scraper's profile discovery)
# Sign up at https://api.search.brave.com — 2000 free queries/month
BRAVE_SEARCH_API_KEY=BSA-your-brave-token

# Apify (REQUIRED for high-quality Instagram email extraction)
# Sign up at https://apify.com to get a token, $5 free credit covers
# ~50-100 profile scrapes. Without this the IG scraper falls back to
# Playwright SSR (only ~5-10% email hit rate); with it the contact_email
# field that IG hides behind login becomes accessible (~40-60% hit rate).
# After signup, copy your token from https://console.apify.com/account/integrations
APIFY_API_TOKEN=apify_api_your-token-here
# Optional: change the actor if you want a different scraper. Default works
# for most cases. Available: apify~instagram-profile-scraper (precise
# profile-only) or apify~instagram-scraper (general-purpose, includes posts).
APIFY_IG_ACTOR=apify~instagram-profile-scraper
# TikTok actor. Current default clockworks~tiktok-scraper (v2 pipeline,
# switched 2026-04-26 from jurassic_jove which had third-party email
# leakage from scrapeEmails=true visiting bio external pages and cost
# ~$3/task). v2 reads only creator-owned bio + caption fields, so emails
# are provably the creator's. Cost ~$0.20-0.60/task at $0.0037/video.
# See docs/ scraper notes if you need to evaluate alternatives.
APIFY_TIKTOK_ACTOR=clockworks~tiktok-scraper
