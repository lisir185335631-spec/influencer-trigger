# ============================================================
# Influencer Trigger - Environment Variables
# Copy this file to .env and fill in your values
# ============================================================

# App
APP_NAME="Influencer Trigger"
DEBUG=false

# Database (SQLite for dev, PostgreSQL for prod)
DATABASE_URL=sqlite+aiosqlite:///./data/influencer.db
# DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/influencer_trigger

# JWT Authentication
SECRET_KEY=your-super-secret-key-change-in-production
ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=30
REFRESH_TOKEN_EXPIRE_DAYS=7

# Encryption key for SMTP passwords (Fernet)
# Generate with: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
ENCRYPTION_KEY=your-fernet-encryption-key-here

# OpenAI
OPENAI_API_KEY=sk-your-openai-api-key
OPENAI_MODEL=gpt-4o
OPENAI_CLASSIFIER_MODEL=gpt-4o-mini

# SendGrid (optional)
SENDGRID_API_KEY=SG.your-sendgrid-api-key

# Mailgun (optional)
MAILGUN_API_KEY=your-mailgun-api-key
MAILGUN_DOMAIN=mg.yourdomain.com

# Redis
REDIS_URL=redis://localhost:6379

# CORS (comma-separated list of allowed origins)
CORS_ORIGINS=["http://localhost:3000","http://127.0.0.1:3000"]

# Webhook Notifications (optional)
FEISHU_WEBHOOK_URL=https://open.feishu.cn/open-apis/bot/v2/hook/your-token
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/your/slack/webhook
